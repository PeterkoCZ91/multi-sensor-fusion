#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Fusion service CLI wrapper
# Resolves the repo root from the script location so it works regardless of
# the current working directory.
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

# Data directory — override with FUSION_DATA_DIR env var.
DATA_DIR="${FUSION_DATA_DIR:-${REPO_DIR}/data}"

# ANSI colours
RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
CYN='\033[0;36m'
RST='\033[0m'

info()  { printf "${CYN}==> %s${RST}\n" "$*"; }
ok()    { printf "${GRN}ok  %s${RST}\n" "$*"; }
warn()  { printf "${YLW}!   %s${RST}\n" "$*"; }
err()   { printf "${RED}ERR %s${RST}\n" "$*" >&2; }

run() {
    printf "${YLW}$ %s${RST}\n" "$*"
    "$@"
}

cd "$REPO_DIR"

CMD="${1:-help}"
shift || true

case "$CMD" in

    status)
        info "Container status"
        run docker compose ps
        echo
        info "Last 5 log lines"
        run docker compose logs --tail 5 fusion
        ;;

    logs)
        N="${1:-50}"
        info "Last ${N} log lines"
        run docker compose logs --tail "$N" fusion
        ;;

    tail)
        info "Following fusion logs (Ctrl-C to stop)"
        run docker compose logs -f fusion
        ;;

    restart)
        info "Restarting fusion service"
        run docker compose restart fusion
        ok "Done"
        ;;

    build)
        info "Building fusion image"
        run docker compose build
        ok "Build complete"
        ;;

    up)
        info "Starting fusion service (detached)"
        run docker compose up -d
        ok "Service started — use '$(basename "$0") tail' to follow logs"
        ;;

    down)
        info "Stopping fusion service"
        run docker compose down
        ok "Service stopped"
        ;;

    events)
        N="${1:-}"
        if [[ -n "$N" ]]; then
            info "Last ${N} event-related log lines"
            run docker compose logs --tail "$N" fusion
        else
            info "Streaming Docker Compose events (Ctrl-C to stop)"
            run docker compose events
        fi
        ;;

    help|--help|-h)
        printf "\n${CYN}Fusion service CLI${RST}\n\n"
        printf "  Data dir: %s\n\n" "$DATA_DIR"
        printf "Usage: %s <command> [args]\n\n" "$(basename "$0")"
        printf "Commands:\n"
        printf "  ${GRN}status${RST}        Show container state and last 5 log lines\n"
        printf "  ${GRN}logs [N]${RST}      Print last N log lines (default: 50)\n"
        printf "  ${GRN}tail${RST}          Follow logs in real time\n"
        printf "  ${GRN}restart${RST}       Restart the fusion container\n"
        printf "  ${GRN}build${RST}         Rebuild the Docker image\n"
        printf "  ${GRN}up${RST}            Start the service (detached)\n"
        printf "  ${GRN}down${RST}          Stop and remove the container\n"
        printf "  ${GRN}events [N]${RST}    Stream Docker events, or show last N log lines\n"
        printf "  ${GRN}help${RST}          Show this help\n\n"
        printf "Environment:\n"
        printf "  FUSION_DATA_DIR   Override data directory (default: %s/data)\n\n" "$REPO_DIR"
        ;;

    *)
        err "Unknown command: ${CMD}"
        printf "Run '%s help' for usage.\n" "$(basename "$0")" >&2
        exit 1
        ;;

esac
