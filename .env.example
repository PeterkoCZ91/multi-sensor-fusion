# Copy this file to `.env` and fill in your secrets. `.env` is gitignored.
# All variables are optional — only set the ones you need.

# --- MQTT broker credentials ---
# MQTT_USER=fusion
# MQTT_PASSWORD=

# --- Telegram bot (for notifications) ---
# Create a bot with @BotFather on Telegram, then get your chat ID from @userinfobot.
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Home Assistant long-lived access token ---
# Generate one in HA: Profile → Security → Long-Lived Access Tokens.
# HA_TOKEN=
